        "import seaborn as sns\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "# a) Load the Titanic dataset\n",
        "titanic = sns.load_dataset('titanic')\n",
        "\n",
        "# b) Extract Age as a NumPy array (removing missing values)\n",
        "age_array = titanic['age'].dropna().to_numpy()\n",
        "\n",
        "print(\"--- Part B ---\")\n",
        "print(f\"First 10 values: {age_array[:10]}\")\n",
        "print(f\"Shape of the array: {age_array.shape}\")\n",
        "\n",
        "# c) Create a multi-dimensional NumPy array\n",
        "# We drop rows where any of these specific columns have NaN\n",
        "subset = titanic[['age', 'fare', 'sibsp', 'parch']].dropna()\n",
        "multi_array = subset.to_numpy()\n",
        "\n",
        "print(\"\\n--- Part C ---\")\n",
        "print(f\"Shape of multi-dimensional array: {multi_array.shape}\")\n",
        "\n",
        "# d) Create a new DataFrame from the array\n",
        "new_df = pd.DataFrame(multi_array, columns=['age', 'fare', 'sibsp', 'parch'])\n",
        "\n",
        "print(\"\\n--- Part D ---\")\n",
        "print(\"First 5 rows of the new DataFrame:\")\n",
        "print(new_df.head())"
