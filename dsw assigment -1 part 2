        "# Insert a number at index 2\n",
        "my_list.insert(2, 25)\n",
        "print(f\"List after inserting 25 at index 2: {my_list}\")\n",
        "\n",
        "# Remove the last element\n",
        "if my_list:\n",
        "    removed_element = my_list.pop()\n",
        "    print(f\"List after removing the last element ({removed_element}): {my_list}\")\n",
        "else:\n",
        "    print(\"List is empty, cannot remove last element.\")\n",
        "\n",
        "# Print the final list\n",
        "print(f\"Final list: {my_list}\")"
